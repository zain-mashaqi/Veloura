<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Line?>

<AnchorPane prefHeight="760.0"
            prefWidth="900.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.veloura.controller.AddSaleController">

    <children>

        <ImageView fitHeight="760.0" fitWidth="900.0" preserveRatio="false">
            <image>
                <Image url="@../images/gold-bg.png"/>
            </image>
        </ImageView>

        <Pane prefHeight="760.0"
              prefWidth="900.0"
              style="-fx-background-color:rgba(3,7,14,0.78);" />

        <Pane layoutX="45.0"
              layoutY="30.0"
              prefHeight="700.0"
              prefWidth="810.0"
              style="-fx-background-color:rgba(4,10,18,0.86);
                     -fx-background-radius:24;
                     -fx-border-color:#8B6526;
                     -fx-border-radius:24;
                     -fx-border-width:1.2;">

            <children>

                <Label layoutX="35.0"
                       layoutY="24.0"
                       text="Add Sale"
                       style="-fx-text-fill:#F8FAFC;
                              -fx-font-family:Georgia;
                              -fx-font-size:34px;" />

                <Label layoutX="38.0"
                       layoutY="73.0"
                       text="Create a new sales invoice with multiple items"
                       style="-fx-text-fill:#C9D3E8;
                              -fx-font-size:14px;" />

                <Line layoutX="35.0"
                      layoutY="106.0"
                      startX="0.0"
                      endX="735.0"
                      stroke="#D4A64A"
                      strokeWidth="1.2" />

                <Label layoutX="55.0" layoutY="130.0" text="Barcode"
                       style="-fx-text-fill:white; -fx-font-size:14px;" />

                <TextField fx:id="txtBarcode"
                           layoutX="170.0"
                           layoutY="121.0"
                           prefHeight="38.0"
                           prefWidth="430.0"
                           promptText="Scan or type barcode then press Enter"
                           style="-fx-background-color:rgba(2,9,16,0.88);
                                  -fx-text-fill:white;
                                  -fx-prompt-text-fill:#9EA7C3;
                                  -fx-background-radius:10;
                                  -fx-border-color:#D4A64A;
                                  -fx-border-radius:10;
                                  -fx-font-size:14px;" />

                <Label layoutX="55.0" layoutY="180.0" text="Customer"
                       style="-fx-text-fill:white; -fx-font-size:14px;" />

                <ComboBox fx:id="cmbCustomer"
                          layoutX="170.0"
                          layoutY="171.0"
                          prefHeight="38.0"
                          prefWidth="430.0"
                          promptText="Select customer"
                          style="-fx-background-color:rgba(2,9,16,0.88);
                                 -fx-background-radius:10;
                                 -fx-border-color:#8B6526;
                                 -fx-border-radius:10;
                                 -fx-font-size:14px;" />

                <Label layoutX="55.0" layoutY="230.0" text="Variant"
                       style="-fx-text-fill:white; -fx-font-size:14px;" />

                <ComboBox fx:id="cmbVariant"
                          layoutX="170.0"
                          layoutY="221.0"
                          prefHeight="38.0"
                          prefWidth="430.0"
                          promptText="Select variant"
                          style="-fx-background-color:rgba(2,9,16,0.88);
                                 -fx-background-radius:10;
                                 -fx-border-color:#8B6526;
                                 -fx-border-radius:10;
                                 -fx-font-size:14px;" />

                <Label layoutX="55.0" layoutY="280.0" text="Quantity"
                       style="-fx-text-fill:white; -fx-font-size:14px;" />

                <TextField fx:id="txtQty"
                           layoutX="170.0"
                           layoutY="271.0"
                           prefHeight="38.0"
                           prefWidth="160.0"
                           promptText="Qty"
                           style="-fx-background-color:rgba(2,9,16,0.88);
                                  -fx-text-fill:white;
                                  -fx-prompt-text-fill:#9EA7C3;
                                  -fx-background-radius:10;
                                  -fx-border-color:#8B6526;
                                  -fx-border-radius:10;
                                  -fx-font-size:14px;" />

                <Button fx:id="btnAddItem"
                        layoutX="350.0"
                        layoutY="270.0"
                        prefHeight="40.0"
                        prefWidth="120.0"
                        text="+ Add Item"
                        onAction="#handleAddItem"
                        style="-fx-background-color:linear-gradient(to bottom,#F2C66D,#B98224);
                               -fx-text-fill:#06101F;
                               -fx-font-size:14px;
                               -fx-font-weight:bold;
                               -fx-background-radius:12;" />

                <Button fx:id="btnRemoveItem"
                        layoutX="485.0"
                        layoutY="270.0"
                        prefHeight="40.0"
                        prefWidth="115.0"
                        text="Remove"
                        onAction="#handleRemoveItem"
                        style="-fx-background-color:transparent;
                               -fx-border-color:#D4A64A;
                               -fx-border-radius:12;
                               -fx-background-radius:12;
                               -fx-text-fill:#E7C16B;
                               -fx-font-size:14px;" />

                <TableView fx:id="tblCart"
                           layoutX="35.0"
                           layoutY="330.0"
                           prefHeight="185.0"
                           prefWidth="735.0"
                           style="-fx-background-color:rgba(2,9,16,0.88);
                                  -fx-control-inner-background:#06101F;
                                  -fx-selection-bar:#B98224;
                                  -fx-table-cell-border-color:transparent;
                                  -fx-background-radius:14;
                                  -fx-border-color:#8B6526;
                                  -fx-border-radius:14;">

                    <columns>
                        <TableColumn fx:id="colProductName" prefWidth="180.0" text="Product" />
                        <TableColumn fx:id="colBarcode" prefWidth="115.0" text="Barcode" />
                        <TableColumn fx:id="colSize" prefWidth="75.0" text="Size" />
                        <TableColumn fx:id="colColor" prefWidth="85.0" text="Color" />
                        <TableColumn fx:id="colQty" prefWidth="65.0" text="Qty" />
                        <TableColumn fx:id="colUnitPrice" prefWidth="95.0" text="Price" />
                        <TableColumn fx:id="colLineTotal" prefWidth="115.0" text="Total" />
                    </columns>
                </TableView>

                <Label layoutX="55.0" layoutY="542.0" text="Payment Method"
                       style="-fx-text-fill:white; -fx-font-size:14px;" />

                <ComboBox fx:id="cmbPaymentMethod"
                          layoutX="190.0"
                          layoutY="533.0"
                          prefHeight="38.0"
                          prefWidth="200.0"
                          promptText="Select payment method"
                          style="-fx-background-color:rgba(2,9,16,0.88);
                                 -fx-background-radius:10;
                                 -fx-border-color:#8B6526;
                                 -fx-border-radius:10;
                                 -fx-font-size:14px;" />

                <Label layoutX="55.0" layoutY="592.0" text="Discount %"
                       style="-fx-text-fill:white; -fx-font-size:14px;" />

                <TextField fx:id="txtDiscount"
                           layoutX="190.0"
                           layoutY="583.0"
                           prefHeight="38.0"
                           prefWidth="200.0"
                           promptText="Discount percentage"
                           style="-fx-background-color:rgba(2,9,16,0.88);
                                  -fx-text-fill:white;
                                  -fx-prompt-text-fill:#9EA7C3;
                                  -fx-background-radius:10;
                                  -fx-border-color:#8B6526;
                                  -fx-border-radius:10;
                                  -fx-font-size:14px;" />

                <Pane layoutX="470.0"
                      layoutY="532.0"
                      prefHeight="90.0"
                      prefWidth="300.0"
                      style="-fx-background-color:rgba(2,9,16,0.55);
                             -fx-background-radius:16;
                             -fx-border-color:#6D5A2A;
                             -fx-border-radius:16;">

                    <children>
                        <Label layoutX="20.0" layoutY="15.0" text="Subtotal:"
                               style="-fx-text-fill:#B8C4D8; -fx-font-size:14px;" />

                        <Label fx:id="lblSubtotal"
                               layoutX="200.0" layoutY="15.0" text="0.00"
                               style="-fx-text-fill:white; -fx-font-size:14px; -fx-font-weight:bold;" />

                        <Label layoutX="20.0" layoutY="50.0" text="Estimated Total:"
                               style="-fx-text-fill:#D4A64A; -fx-font-size:15px; -fx-font-weight:bold;" />

                        <Label fx:id="lblEstimatedTotal"
                               layoutX="190.0" layoutY="48.0" text="0.00"
                               style="-fx-text-fill:#D4A64A; -fx-font-size:17px; -fx-font-weight:bold;" />
                    </children>
                </Pane>

                <Label fx:id="lblMessage"
                       layoutX="55.0"
                       layoutY="645.0"
                       prefWidth="430.0"
                       style="-fx-text-fill:#FFD166;
                              -fx-font-size:13px;" />

                <Button fx:id="btnSave"
                        layoutX="560.0"
                        layoutY="635.0"
                        prefHeight="42.0"
                        prefWidth="120.0"
                        text="Create Sale"
                        onAction="#handleSave"
                        style="-fx-background-color:linear-gradient(to bottom,#F2C66D,#B98224);
                               -fx-text-fill:#06101F;
                               -fx-font-size:14px;
                               -fx-font-weight:bold;
                               -fx-background-radius:12;" />

                <Button fx:id="btnCancel"
                        layoutX="692.0"
                        layoutY="635.0"
                        prefHeight="42.0"
                        prefWidth="90.0"
                        text="Cancel"
                        onAction="#handleCancel"
                        style="-fx-background-color:transparent;
                               -fx-border-color:#D4A64A;
                               -fx-border-radius:12;
                               -fx-background-radius:12;
                               -fx-text-fill:#E7C16B;
                               -fx-font-size:14px;" />

            </children>
        </Pane>
    </children>
</AnchorPane>