<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<HBox fx:id="rootPane"
      prefHeight="640.0"
      prefWidth="980.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.veloura.controller.DashboardController">

    <children>

        <AnchorPane fx:id="sidebarPane" prefHeight="640.0" prefWidth="250.0">
            <children>

                <ImageView fitHeight="640.0" fitWidth="250.0" preserveRatio="false">
                    <image>
                        <Image url="@../images/gold-bg.png"/>
                    </image>
                </ImageView>

                <Pane prefHeight="640.0" prefWidth="250.0"
                      style="-fx-background-color:rgba(2,5,10,0.70);" />

                <Line layoutX="249.0" layoutY="0.0"
                      startX="0.0" startY="0.0"
                      endX="0.0" endY="640.0"
                      stroke="#D4A64A"
                      strokeWidth="1.1"/>

                <Label fx:id="lblStoreName"
                       layoutX="55.0"
                       layoutY="42.0"
                       text="VELOURA"
                       style="-fx-text-fill:#D4A64A; -fx-font-size:28; -fx-font-weight:bold;" />

                <VBox layoutX="26.0" layoutY="112.0" prefHeight="495.0" prefWidth="198.0" spacing="13.0">
                    <children>

                        <Button fx:id="btnDashboard"
                                text="▥  Dashboard"
                                onAction="#goToDashboard"
                                prefHeight="42.0"
                                prefWidth="198.0"
                                style="-fx-background-color:linear-gradient(to right,#F2C66D,#B98224);
                                       -fx-text-fill:#06101F;
                                       -fx-font-size:14;
                                       -fx-font-weight:bold;
                                       -fx-background-radius:12;" />

                        <Button fx:id="btnProducts"
                                text="▣  Products"
                                onAction="#goToProducts"
                                prefHeight="42.0"
                                prefWidth="198.0"
                                style="-fx-background-color:rgba(2,9,16,0.50);
                                       -fx-text-fill:#F8FAFC;
                                       -fx-font-size:14;
                                       -fx-background-radius:12;
                                       -fx-border-color:#8B6526;
                                       -fx-border-radius:12;" />

                        <Button fx:id="btnCustomers"
                                text="♟  Customers"
                                onAction="#goToCustomers"
                                prefHeight="42.0"
                                prefWidth="198.0"
                                style="-fx-background-color:rgba(2,9,16,0.50);
                                       -fx-text-fill:#F8FAFC;
                                       -fx-font-size:14;
                                       -fx-background-radius:12;
                                       -fx-border-color:#8B6526;
                                       -fx-border-radius:12;" />

                        <Button fx:id="btnSales"
                                text="🛒  Sales"
                                onAction="#goToSales"
                                prefHeight="42.0"
                                prefWidth="198.0"
                                style="-fx-background-color:rgba(2,9,16,0.50);
                                       -fx-text-fill:#F8FAFC;
                                       -fx-font-size:14;
                                       -fx-background-radius:12;
                                       -fx-border-color:#8B6526;
                                       -fx-border-radius:12;" />

                        <Button fx:id="btnInventory"
                                text="▣  Inventory"
                                onAction="#goToInventory"
                                prefHeight="42.0"
                                prefWidth="198.0"
                                style="-fx-background-color:rgba(2,9,16,0.50);
                                       -fx-text-fill:#F8FAFC;
                                       -fx-font-size:14;
                                       -fx-background-radius:12;
                                       -fx-border-color:#8B6526;
                                       -fx-border-radius:12;" />

                        <Button fx:id="btnUsers"
                                text="♙  Users"
                                onAction="#goToUsers"
                                prefHeight="42.0"
                                prefWidth="198.0"
                                style="-fx-background-color:rgba(2,9,16,0.50);
                                       -fx-text-fill:#F8FAFC;
                                       -fx-font-size:14;
                                       -fx-background-radius:12;
                                       -fx-border-color:#8B6526;
                                       -fx-border-radius:12;" />

                        <Button fx:id="btnProductStats"
                                text="📈  Product Stats"
                                onAction="#goToProductStats"
                                prefHeight="42.0"
                                prefWidth="198.0"
                                style="-fx-background-color:rgba(212,166,74,0.18);
                                       -fx-text-fill:#D4A64A;
                                       -fx-font-size:14;
                                       -fx-font-weight:bold;
                                       -fx-background-radius:12;
                                       -fx-border-color:#D4A64A;
                                       -fx-border-radius:12;" />

                        <Button fx:id="btnLogout"
                                text="↩  Logout"
                                onAction="#handleLogout"
                                prefHeight="42.0"
                                prefWidth="198.0"
                                style="-fx-background-color:transparent;
                                       -fx-text-fill:#F8FAFC;
                                       -fx-font-size:14;" />

                    </children>
                </VBox>

            </children>
        </AnchorPane>

        <AnchorPane fx:id="contentPane" prefHeight="640.0" prefWidth="730.0">
            <children>

                <ImageView fitHeight="640.0" fitWidth="730.0" preserveRatio="false">
                    <image>
                        <Image url="@../images/gold-bg.png"/>
                    </image>
                </ImageView>

                <Pane prefHeight="640.0" prefWidth="730.0"
                      style="-fx-background-color:rgba(3,7,14,0.68);" />

                <Label fx:id="lblWelcomeTitle"
                       layoutX="45.0"
                       layoutY="42.0"
                       text="Welcome to Veloura Dashboard"
                       style="-fx-text-fill:#F8FAFC; -fx-font-size:28px; -fx-font-family:Georgia;" />

                <Label fx:id="lblSubtitle"
                       layoutX="47.0"
                       layoutY="88.0"
                       text="Overview of your store activity"
                       style="-fx-text-fill:#D4A64A; -fx-font-size:15;" />

                <Label fx:id="lblCurrentUser"
                       layoutX="560.0"
                       layoutY="45.0"
                       text="User: -"
                       style="-fx-text-fill:white; -fx-font-size:14; -fx-font-weight:bold;" />

                <Label fx:id="lblTodayDate"
                       layoutX="560.0"
                       layoutY="73.0"
                       text="Today: -"
                       style="-fx-text-fill:#D4A64A; -fx-font-size:13;" />

                <GridPane hgap="24.0"
                          vgap="24.0"
                          layoutX="45.0"
                          layoutY="145.0"
                          prefHeight="340.0"
                          prefWidth="640.0">

                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>

                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>

                    <children>

                        <Pane fx:id="cardProducts"
                              prefHeight="155.0"
                              prefWidth="295.0"
                              style="-fx-background-color:rgba(4,10,18,0.78);
                                     -fx-background-radius:22;
                                     -fx-border-color:#8B6526;
                                     -fx-border-radius:22;">

                            <children>
                                <Label layoutX="132.0" layoutY="28.0"
                                       text="▣"
                                       style="-fx-text-fill:#D4A64A; -fx-font-size:32;" />

                                <Label layoutX="102.0" layoutY="70.0"
                                       text="Total Products"
                                       style="-fx-text-fill:white; -fx-font-size:15;" />

                                <Label fx:id="lblTotalProducts"
                                       layoutX="137.0" layoutY="100.0"
                                       text="0"
                                       style="-fx-text-fill:#D4A64A; -fx-font-size:30; -fx-font-weight:bold;" />
                            </children>
                        </Pane>

                        <Pane fx:id="cardCustomers"
                              prefHeight="155.0"
                              prefWidth="295.0"
                              GridPane.columnIndex="1"
                              style="-fx-background-color:rgba(4,10,18,0.78);
                                     -fx-background-radius:22;
                                     -fx-border-color:#8B6526;
                                     -fx-border-radius:22;">

                            <children>
                                <Label layoutX="132.0" layoutY="28.0"
                                       text="♙"
                                       style="-fx-text-fill:#D4A64A; -fx-font-size:32;" />

                                <Label layoutX="96.0" layoutY="70.0"
                                       text="Total Customers"
                                       style="-fx-text-fill:white; -fx-font-size:15;" />

                                <Label fx:id="lblTotalCustomers"
                                       layoutX="137.0" layoutY="100.0"
                                       text="0"
                                       style="-fx-text-fill:#D4A64A; -fx-font-size:30; -fx-font-weight:bold;" />
                            </children>
                        </Pane>

                        <Pane fx:id="cardSalesProcessing"
                              prefHeight="155.0"
                              prefWidth="295.0"
                              GridPane.rowIndex="1"
                              style="-fx-background-color:rgba(4,10,18,0.78);
                                     -fx-background-radius:22;
                                     -fx-border-color:#8B6526;
                                     -fx-border-radius:22;">

                            <children>
                                <Label layoutX="132.0" layoutY="28.0"
                                       text="🛒"
                                       style="-fx-text-fill:#D4A64A; -fx-font-size:30;" />

                                <Label layoutX="92.0" layoutY="70.0"
                                       text="Sales Processing"
                                       style="-fx-text-fill:white; -fx-font-size:15;" />

                                <Label fx:id="lblSalesProcessing"
                                       layoutX="137.0" layoutY="100.0"
                                       text="0"
                                       style="-fx-text-fill:#D4A64A; -fx-font-size:30; -fx-font-weight:bold;" />
                            </children>
                        </Pane>

                        <Pane fx:id="cardTotalSales"
                              prefHeight="155.0"
                              prefWidth="295.0"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="1"
                              style="-fx-background-color:rgba(4,10,18,0.78);
                                     -fx-background-radius:22;
                                     -fx-border-color:#8B6526;
                                     -fx-border-radius:22;">

                            <children>
                                <Label layoutX="132.0" layoutY="28.0"
                                       text="📈"
                                       style="-fx-text-fill:#D4A64A; -fx-font-size:30;" />

                                <Label layoutX="111.0" layoutY="70.0"
                                       text="Total Sales"
                                       style="-fx-text-fill:white; -fx-font-size:15;" />

                                <Label fx:id="lblTotalSales"
                                       layoutX="110.0" layoutY="100.0"
                                       text="0.00"
                                       style="-fx-text-fill:#D4A64A; -fx-font-size:30; -fx-font-weight:bold;" />
                            </children>
                        </Pane>

                    </children>
                </GridPane>

            </children>
        </AnchorPane>

    </children>
</HBox>